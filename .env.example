# Copy to .env and fill in. Provider can be: groq | openai | anthropic | mock
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional alternative providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings model (fastembed / ONNX, local). Fallback vectorizer used if unavailable.
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Auto-approval confidence threshold (graduated-autonomy policy adapts around this)
AUTO_APPROVE_THRESHOLD=0.85
